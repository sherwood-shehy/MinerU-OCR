# Copy this file to .env and fill in your real credentials.
# Never commit a real .env file — it is gitignored for safety.

# === MinerU Cloud OCR (required) ===
# Obtain from https://mineru.net/apiManage
MINERU_API_TOKEN=<your_mineru_api_token>

# === AI Enhancement Layer (optional, only required when using --enhance) ===
# Doubao-Seed-2.0-lite via Volcengine Coding Plan
# Obtain from https://console.volcengine.com/ark
DOUBAO_API_KEY=<your_doubao_api_key>

# Optional overrides — defaults work for Volcengine Coding Plan
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
DOUBAO_MODEL=doubao-seed-2.0-lite
